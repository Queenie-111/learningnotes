#排序
#sort：将列表按特定的顺序重新排序，默认从小到大
li=['1','4','67','3','5']
li.sort()
print(li)  #输出为1、3、4、5、67

#reverse，将整个列表倒过来，5，3，67，4，1，如果和sort一起用就可以实现从大到小的效果
li.sort()
li.reverse()
print(li)   #输出为67，5，4，3，1

#列表推导式
#格式一：[表达式 for 变量 in 列表] in后面不仅可以放列表还可以放range（）、可迭代对象
li=[1,2,3,4,5,6]
#[print(i) for i in li] 前面的i是表达式
li=[]
for i in range (1,6):
    #print(i)
    li.append(i)  #把li元素1放进列表中了
print(li)

[li.append(i) for i in range(1,6)]
print(li)  #结果和上方相同

#格式二：[表达式 for 变量 in 列表 if 条件]
#把奇数放入列表
li=[]
for i in range (1,6):
    if i%2==1:  #表示余数为1，则i是奇数
        li.append(i)
print(li)    #输出为135
#用格式表示
[li.append(i) for i in range(1,6) if i%2==1]
print(li)


#列表嵌套   一个列表里面又有一个列表
li=[1,2,3,[4,5,6]]  #[4,5,6]是里面的列表
print(li[3]) #输出的为里面的整个列表因为是取出下标
print(li[3][2])   #取出内列表里的元素，下标为2的元素
