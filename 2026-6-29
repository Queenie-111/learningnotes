#切片  指对操作的对象截取其中一部分的操作
#[开始位置：结束位置:步长]，前面两个是取值方向，最后一个数代表步长，且步长表示切取方向
# 遵循包前不包后原则：即从起始位置开始到结束位置的前一位结束（不包含结束位置本身）
#步长：表示选取间隔，不写步长则默认是1，步长的绝对值大小决定切取的间隔，
# 正负号决定切取的方向，正数表示从左往右取值，负数从右往左
st="wonderful"
print(st[0:4])  #wond
print(st[3:])   #derful
print(st[:4])   #wond
print(st[-1:])  #l
print(st[:-1])  #wonderfu   #其实以上每个公式都在最后默认：1，但是没写出来，如果想要他反着取，就写-1
#eg：print（st[-1:-5:-1])  输出为：lufr
print(st[0:8:2])  #wnef


#字符串常见操作
#查找find，检测某个字符串是否包含在字符串中，如果在就返回这个字符串开始位置的下标，，否则就返回-1
print(st.find("n"))  #2
print(st.find("d",6)) #输出为-1，不管下标位于第几位，输出都是-1
#遵循包前不包后原则
print(st.find("n",1,2)) #虽然n下标位于2，但是遵循包前不包后原则，输出-1

#index():检测某个子字符串是否包含在字符串中，如果在就返回这个字符串开始位置的下标，否则报错
print(st.index("n"))   #2
print(st.index("n",4))  #会报错，因为从这里开始后面没有包含n这个子字符的
#同样遵循包前不包后的原则，与find不同的是，find没找到，返回-1，index没找到报错

#count（）：返回某个子字符串在整个字符串中出现的次数，没有就返回0
print(st.count("n")) #1  只出现了一次
print(st.count("a")) #0  没有出现


#判断
#startswith（）；判断是否以某个字符串开头，是的话就返回ture，不是的话就返回false，如果设置开始和结束位置下标，
#               则在指定范围内检查
#endswith():判断是否以某个子字符串结尾，是就返回徒惹，不是就返回false，也可以设置检查范围内

st="wonerful"
print(st.startswith("w"))   #ture
print(st.startswith("o"))   #false
print(st.endswith("w"))     #false
print(st.endswith("l"))     #ture

