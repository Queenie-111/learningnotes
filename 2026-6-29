    print(i)


#列表相关操作
#添加元素：append（）  extend（）   insert（）
li=["one","two","three"]
li.append("four")   #整体添加
print(li)   #输出为"one","two","three"，“four”字符作为一个整体添加

li.extend("four")    #分散添加
print(li)   #输出为"one","two","three","f","o","u","r" 分散添加，将一个类型中的元素逐个添加

li.insert(0,"four")   #在指定位置添加
print(li)   #输出为“four”，"one","two","three"，指定位置如果有元素，原有元素会后移

#修改元素，直接通过下标直接进行修改
li=[1,2,3]
li[2]="a"
