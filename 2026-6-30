#浅拷贝（数据半共享）
#会创建新的对象，拷贝第一层的数据，嵌套层会指向原来的内存地址
import copy  #导入copy模块
li=[1,2,3,[4,5,6]]    #定义一个嵌套列表
li2=copy.copy(li)     #浅拷贝
print('li',li)
print('li2',li2)
#查看内存地址 id()
print('lin memory address:',id(li))
print('li2 memory address:',id(li2))  #输出内存地址不一样，说明不是同一个
li.append(8)  #输出后可以看见li新增一个8，但是li2没有添加
#往嵌套列表里面添加元素
li[3].append(7)   #这个3是下标位置
#会发现li和li2都在嵌套列表里加了3，于是查看内存地址
print('li[3]memory address:',id(li[3]))
print('li2[3] memory address:',id(li2[3]))  #可以发现嵌套列表的内存地址都是一样的
#内外层的内存地址不同，可知浅拷贝只能对外层列表进行修改


#深拷贝（数据完全不共享）
#外层的对象和内部的元素都拷贝了一遍
import copy  #导入copy模块
li=[1,2,3,[4,5,6]]
li2=copy.deepcopy(li)    #深拷贝
print('li:',li,id(li))
print('li2:',li2,id(li2))  #可以查看内存地址位置不同
li.append(8)
print(li)
print(li2)  #可以查看外部li添加了8，li2未添加
#再嵌套列表添加
li[3].append(7)
print(li,id(li[3]))
print(li2,id(li2[3]))  #可以发现内层嵌套发生改变，且内存嵌套的内存地址不同
#深拷贝数据变化只影响自己本身，跟原来的对象没有关联
