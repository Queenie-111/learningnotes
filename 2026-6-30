#字典
#基本格式：字典名={键1:值1,键2:值2...)
#键值对形式保存，键和值之间用：隔开，每个键值之间用，隔开
dic={'name':"huahua",'age':18}
#键具备唯一性，值可以重复，被覆盖

#查找元素
#变量名【键名】
print(dic['name'])
print(dic['age'])    #输出为huahua，不可以用下标查找
#变量名.get(键名)
print(dic.get('name')) #输出huahua，如果查找键名不存在则返回none

#修改元素
dic['age']=20  #字典通过键名修改，列表通过下标修改

#添加元素
#变量名[键名]=值
dic['tel']=12345   #这个方式在键名里面有就是修改，没有就是添加

#删除元素
#del  删除整个字典，直接del dic，再打印就会报错，因为已经删除
#删除指定键名
del dic['age']
print(dic)   #则不会输出age
#clear():清空整个字典的东西，但保留了这个字典
dic.clear()
print(dic)   #输出为{}字典，只保留字典
#pop()删除指定键值，键不存在报错
#dic.pop('name')  #会删除后面店值(此处删除了name前面的运行会报错，如果添加一个#，运行恢复正常）


dic['name']='huahua'

#len()求长度
dic={'name':'huahua','age':18,'tel':12345}
print(len(dic))  #3,字典中有三个键值对
#还可以求列表、字符串

#keys() 返回字典里面包含的所有键名
dic={'name':'huahua','age':18,'tel':12345}
print(dic.keys())   #输出为dic_keys(['name','age','tel'])
#也可以使用for循环取出键名
for i in dic.keys():
    print(i)

#values(): 返回字典里面包含的所有值
print(dic.values())
#for循环的方式
for i in dic.values():
    print(i)

#item() 返回字典里面包含的所有键值对，键值对以元组形式
print(dic.items())
#for循环输出
for i in dic.items():
    print(i)  #i是元组类型

#字典的应用场景：使用键值对，储存描述一个物体的相关信息like我的备注


#集合 set
#基本格式：集合名={元素1，元素2，元素3。。。}，定义一个空集合  s1=set（）,集合具有无序性
#        如果是数字，输出将按照集合，如果是字符串可能在每次运行中都无序出现
s1={1,2,3}
#集合无序的实现方式涉及hash表
#print（hash('a'))
#print（hash('b'))
#print（hash('c'))   这三个数输出的可能是一串看似混乱的数字
#每次运行的结果都不同，hash值不同，那么在hash表中的位置也不同，这就实现了集合的无序性
#print(hash(1))
#print(hash(2))
#print(hash(3))    这三个输出的结果分别为1、2、3
#python中int整型的hash值就是它本身，在hash表中的位置也不相同，所以顺序不同
