#唯一性
s1={1,2,4,6,3,2,4}
print(s1)  #输出为{1，2，3，4，6}因为具有唯一性，所以可以自动去重（重复）

#集合常见操作

#添加元素
# add()添加的是一个整体
s2={1,2,3,4}
print("before:",s2)
#集合的唯一性决定了如果需要添加的元素在原集合中已经存在，就不进行任何操作
s2.add(5)  #一次次只能添加一个元素，或者加一个元组(5,6)
print("now:",s2)

#update 把传入的元素拆分，一个个放进集合中
s2={1,2,3,4}
s2.update('567')#可以添加可迭代对象：字符串（输出是无序的）、列表、元组、集合
s2.update({7,8,9})
print(s2)

#删除元素
#remove选择删除的元素，如果集合中有就会删除，没有就会报错
s2={1,2,3,4}
s2.remove(4)
print(s2)  #输出为1，2，3

#pop 对集合进行无序排列，任何将左边的第一个元素删除
s2={1,2,3,4}
print("before:",s2)
s2.pop()   #默认删除根据hash表排序后的第一个元素
print("now:",s2)

#discard  选择要删除的元素，有就删除，没有就不会进行任何操作
s2={1,2,3,4}
print("before:",s2)
s2.discard(4)
print("now:",s2)


