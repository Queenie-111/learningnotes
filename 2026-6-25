一、语句循环
#基本语法
while条件：循环体，改变变量
i=1  #定义应该初始值，记录循环的次数，i=1表示从第一次开始
while1<=100;
  print("好好学习天天向上"）   #此次条件完全符合，会一直陷入循环，需要手动停止，按控制台左边的红色方块！！！不然电脑会卡机
  i+=1  #条件变量，如果不加就会一直循环，表示每循环一次i的值就加1，因为while本来就是语句循环的语法，所以这个公式会不断循环，利用i+1=i的方式不断增加i的变量
  

#死循环
while ture：   #ture或除了0、false之外的所有数和语句都可以死循环
     print（“seccess”）  #这样的话，会一直运行，一直循环直到按下停止
while false：     
     print（“seccess”） #false就是不循环，0也不循环，直接不运行

#while循环应用：计算1+2+3+...+100的和
i=1    #定义应该初始值，从1开始计算，记录循环次数
s=0    #定义一个变量保存计算结果，最开始计算结果为0，没有相加
while i <=100:
   # print(i)    #此处i为数值不是字符，所以不加引号
    s+=i        #每次循环结果和i进行相加
    i+=1        #s在前的愿意是s为0，+i后为1，如果i写在前面，s就变成2开始了
    #print("outcome:",s)  #此时还在循环输出，因为在循环内
print("outcome:",s) #此时结果为总和结果，在循环外，相加后了

