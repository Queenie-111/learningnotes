一、语句循环
#基本语法
while条件：循环体，改变变量
i=1  #定义应该初始值，记录循环的次数，i=1表示从第一次开始
while1<=100;
  print("好好学习天天向上"）   #此次条件完全符合，会一直陷入循环，需要手动停止，按控制台左边的红色方块！！！不然电脑会卡机
  i+=1  #条件变量，如果不加就会一直循环，表示每循环一次i的值就加1，因为while本来就是语句循环的语法，所以这个公式会不断循环，利用i+1=i的方式不断增加i的变量
  

#死循环
while ture：   #ture或除了0、false之外的所有数和语句都可以死循环
     print（“seccess”）  #这样的话，会一直运行，一直循环直到按下停止
while false：     
     print（“seccess”） #false就是不循环，0也不循环，直接不运行

#while循环应用：计算1+2+3+...+100的和
i=1    #定义应该初始值，从1开始计算，记录循环次数
s=0    #定义一个变量保存计算结果，最开始计算结果为0，没有相加
while i <=100:
   # print(i)    #此处i为数值不是字符，所以不加引号
    s+=i        #每次循环结果和i进行相加
    i+=1        #s在前的愿意是s为0，+i后为1，如果i写在前面，s就变成2开始了
    #print("outcome:",s)  #此时还在循环输出，因为在循环内
print("outcome:",s) #此时结果为总和结果，在循环外，相加后了


#while循环嵌套
#基本格式：       #注意缩进决定层级
#while循环条件1：
#     循环体1
#     while循环条件2：
#          循环体2
#          改变变量2
#      改变变量1
i=1
while i<=3:
    print(f"This is the {i} iteration of the outer loop")  #这是第i次外循环
    j=1
    while j<=5:
        print(f"This is the  {j}  iteration of the inner loop")  #这是第j次内循环
        j+=1
    i+=1


#for循环
#for 临时变量 in 可迭代对象：  #字符串就是可迭代对象，如果是数字就加上引号让它变成字符串也就是可迭代对象
#    循环体                 #注意冒号和缩进
str="hellopython"          #定义一个字符串，目标是提取出这个字符串里面的每一个字母
for i in str:              #i是临时变量，可以随便写，i是常规写法
    print(i)

#range  用来记录循环次数，相当于一个计数器
for i in range(1,6):   #表示从1开始，从6结束，但是只输出1到5，遵循包前不包后规则，类似【），括号内只写一个数，就是数值表示的次数，且默认从0开始
    print(i)

#for循环应用：计算1+2+3+...+100的和
s=0  #定义一个变量来保存计算结果
for i in range(1,101):    #包前不包后，不包含101，从1-100
    #print(i)
    s+=i  #每循环一次计算结果与i进行相加
    #print(“计算结果：”，s)    #输出表现为循环
print("The calculation result is ",s)


#break和continue    #都是在循环中专门使用的关键字
#break某一条件满足时，退出循环
i=1
while i<=5:
    print(f"she is eating the {i} apple ")   #一共5个苹果，吃到第3个的时候吃饱了，break停下
    if i=3:
        print("enough")   #结束break所在的这个内循环
        break
    i+=1   #吃的个数在叠加
#continue退出本次循环，下一次循环继续执行
i=1
while i<=5:
    print(f"she is eating the {i} apple ")
    if i==3:
        print("She found a worm in her food,stop eating the {i} apple ")
              i+=1   #一定要在continue前面修改计数器，不然吃到第三个退出循环后依旧死循环
              continue
    i+=1




